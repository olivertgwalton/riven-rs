# System
PUID=1000
PGID=1000
TZ=Europe/London

# Storage - path on the host to mount into riven and jellyfin containers
RIVEN_STORAGE_PATH=/path/to/riven-storage

# Domain
PASSKEY_RP_ID=riven.example.com
ORIGIN=https://riven.example.com

# Auth (shared API key used by both riven and riven-frontend)
# Generate with: openssl rand -hex 32
RIVEN_SETTING__API_KEY=your-api-key-here
BACKEND_API_KEY=your-api-key-here
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Frontend
DATABASE_URL=/riven/data/riven.db
BACKEND_URL=http://riven:8080

# Postgres
POSTGRES_USER=riven
POSTGRES_PASSWORD=riven
POSTGRES_DB=riven

# Riven settings
RIVEN_SETTING__DATABASE_URL=postgresql://riven:riven@postgres/riven
RIVEN_SETTING__REDIS_URL=redis://redis:6379
RIVEN_SETTING__GQL_PORT=8080
RIVEN_SETTING__LOG_LEVEL=debug

# Plugin settings - Seerr
RIVEN_PLUGIN_SETTING__SEERR__APIKEY=
RIVEN_PLUGIN_SETTING__SEERR__URL=
RIVEN_PLUGIN_SETTING__SEERR__FILTER=approved

# Plugin settings - TMDB
RIVEN_PLUGIN_SETTING__TMDB__APIKEY=your-tmdb-api-key

# Plugin settings - Debrid (pick one)
RIVEN_PLUGIN_SETTING__STREMTHRU__REALDEBRIDAPIKEY=

# Plugin settings - Plex (optional)
PLEX_TOKEN=
PLEX_URL=

# Plugin settings - Notifications (optional, JSON array)
# Discord: discord://webhookId/webhookToken
# JSON webhook: json://host/path or jsons://host/path
RIVEN_PLUGIN_SETTING__NOTIFICATIONS__URLS=[]
